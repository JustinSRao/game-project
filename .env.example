# Copy this file to `.env` and fill in a key. `.env` is gitignored — it must
# never be committed, and the key must never be pasted into a chat or issue.
#
# The Director needs exactly one provider. If both keys are present, OpenAI
# wins; set HOWEVERFAR_PROVIDER to force one.

OPENAI_API_KEY=sk-proj-...

# HOWEVERFAR_PROVIDER=openai        # or "anthropic", or "none" for browse-only
# ANTHROPIC_API_KEY=sk-ant-...

# Which OpenAI models back each role. Defaults live in
# packages/director/src/config.ts; run `npm run models -w @howeverfar/director`
# to list what your key can actually reach.
# HOWEVERFAR_OPENAI_MODEL_STRONG=gpt-5
# HOWEVERFAR_OPENAI_MODEL_CHEAP=gpt-5-mini

# --- Spend guardrails (ADR-0018) ---
# Soft per-playthrough budget in USD. Going over cuts optional spend
# (speculation first) and never blocks an area a player is waiting for.
# HOWEVERFAR_SESSION_BUDGET_USD=3
# HOWEVERFAR_MAX_SPECULATIONS=12
# HOWEVERFAR_REUNION_BUDGET_USD=4

# --- The Reunion DLC (ADR-0024, docs/REUNION.md) ---
# The secret licence keys are minted and verified with. Without it the server
# REFUSES the Reunion rather than giving it away.
#   npm run mint -w @howeverfar/entitlement -- buyer@example.com
# HOWEVERFAR_LICENSE_SECRET=
#
# Development only: play the finale without a key. Deliberately separate from
# "no secret configured", so an unconfigured build never looks unlocked.
# HOWEVERFAR_REUNION_UNLOCKED=1
